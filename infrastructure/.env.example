COMPOSE_PROJECT_NAME="tasksmanager-node"
# Database Core (Postgres)
DB_USER=admin
DB_PASSWORD=secret_pass
DB_NAME=taskmanager_local
DATABASE_URL=postgresql://admin:secret_pass@postgres:5432/taskmanager_local?schema=public

# Logs (MongoDB)
MONGO_USER=admin
MONGO_PASSWORD=secret_mongo_pass
MONGO_URL=mongodb://admin:secret_mongo_pass@mongodb:27017/taskmanager_logs?authSource=admin

# App
NODE_ENV=development